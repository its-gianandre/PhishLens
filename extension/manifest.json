{
  "manifest_version": 3,
  "name": "PhishLens",
  "version": "0.1.0",
  "description": "Explainable, real-time phishing detection: a transparent risk score backed by evidence you can verify.",
  "minimum_chrome_version": "120",
  "permissions": ["storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishLens"
  }
}
